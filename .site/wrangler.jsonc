{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "macquerade-site",
  // account_id intentionally omitted: Wrangler reads CLOUDFLARE_ACCOUNT_ID from
  // the environment or a .env file in this directory (see .env.example).
  "compatibility_date": "2026-07-10",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    { "pattern": "macquerade.enflamemedia.com", "custom_domain": true }
  ]
}
