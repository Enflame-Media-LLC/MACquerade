{
  "name": "@macquerade/site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite-ssg build && rm -rf dist/.vite",
    "preview": "vite preview",
    "lint": "oxlint .",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@vueuse/core": "^14.3.0",
    "@vueuse/motion": "^3.0.3",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.10.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^25.0.1",
    "oxlint": "^1.68.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vite-ssg": "^28.3.0",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.0.0",
    "wrangler": "^4.110.0"
  }
}
