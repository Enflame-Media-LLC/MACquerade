{
  "name": "spoof",
  "description": "Easily spoof your MAC address in macOS, Linux & Windows",
  "version": "2.0.4",
  "author": {
    "name": "Feross Aboukhadijeh",
    "email": "feross@feross.org",
    "url": "https://feross.org"
  },
  "bin": "./dist/cli.js",
  "bugs": {
    "url": "https://github.com/TheJACKedViking/spoof/issues"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "common-tags": "^1.8.2",
    "minimist": "^1.2.8",
    "winreg": "^1.2.5"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/common-tags": "^1.8.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^25.5.0",
    "@types/winreg": "^1.2.36",
    "@vitest/coverage-v8": "^4.1.2",
    "oxlint": "^1.57.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "homepage": "https://github.com/TheJACKedViking/spoof#readme",
  "keywords": [
    "MAC address",
    "address",
    "change",
    "mac",
    "macchanger",
    "mad science",
    "modify",
    "set mac",
    "spoof",
    "spoof mac address",
    "spoofmac"
  ],
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheJACKedViking/spoof.git"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly",
    "start": "node dist/cli.js",
    "test": "yarn build && yarn lint && vitest run",
    "test:only": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "yarn build && vitest run --coverage",
    "coverage": "yarn build && vitest run --coverage",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "typecheck": "tsc --noEmit",
    "validate": "yarn build && yarn lint && vitest run",
    "validate:strict": "yarn typecheck && yarn build && yarn lint && vitest run",
    "prepublishOnly": "yarn validate:strict",
    "preversion": "yarn validate:strict",
    "postversion": "git push && git push --tags",
    "clean": "rm -rf node_modules dist .yarn/cache .yarn/install-state.gz",
    "reinstall": "yarn clean && yarn install",
    "update-oui": "npx tsx scripts/update-oui.ts",
    "mutation": "npx stryker run",
    "stryker": "npx stryker run"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/feross"
    },
    {
      "type": "patreon",
      "url": "https://www.patreon.com/feross"
    },
    {
      "type": "consulting",
      "url": "https://feross.org/support"
    }
  ],
  "resolutions": {
    "picomatch": "^4.0.4",
    "tar": "^7.5.11",
    "minimatch": "^10.2.4",
    "rollup": "^4.59.0",
    "@isaacs/brace-expansion": "^5.0.1"
  },
  "packageManager": "yarn@4.12.0",
  "engines": {
    "node": ">=24"
  }
}
